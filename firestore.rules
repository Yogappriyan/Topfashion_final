rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email in ['vkalvaro1005@gmail.com', 'vishwa10230506@gmail.com'] ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'admin')
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Categories
    match /categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidId(categoryId);
    }

    // Settings
    match /settings/{settingsId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidId(settingsId);
    }

    // Products
    match /products/{productId} {
      allow read: if true;
      allow create, delete: if isAdmin() && isValidId(productId);
      allow update: if isValidId(productId) && (isAdmin() || (
        incoming().diff(existing()).affectedKeys().hasOnly(['stock']) &&
        incoming().stock is number && incoming().stock >= 0
      ));
      
      function isValidProduct(data) {
        return data.keys().hasAll(['name', 'description', 'price', 'category', 'images', 'stock'])
            && data.keys().size() == 6
            && data.name is string && data.name.size() > 0 && data.name.size() < 200
            && data.description is string && data.description.size() < 5000
            && data.price is number && data.price >= 0
            && data.category is string
            && data.images is list && data.images.size() > 0
            && data.stock is number && data.stock >= 0;
      }
    }

    // Connection Test
    match /_connection_test_/{docId} {
      allow read: if true;
    }

    // Orders
    match /orders/{orderId} {
      allow create: if isValidId(orderId) && isValidOrder(incoming());
      allow get: if true;
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin() && isValidId(orderId);
      
      function isValidOrder(data) {
        return data.userId is string && data.userId.size() > 0
            && data.items is list && data.items.size() > 0
            && data.total is number && data.total >= 0
            && data.status in ['pending', 'New Express Order', 'Preparing', 'processing', 'shipped', 'out_for_delivery', 'out for delivery', 'delivered', 'cancelled']
            && (data.createdAt is timestamp || data.createdAt == request.time);
      }
    }

    // Reviews
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidId(reviewId) && incoming().userId == request.auth.uid && isValidReview(incoming());
      allow delete: if (isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid)) && isValidId(reviewId);
      
      function isValidReview(data) {
        return data.productId is string
            && data.userId == request.auth.uid
            && data.rating is number && data.rating >= 1 && data.rating <= 5
            && data.comment is string && data.comment.size() < 1000
            && data.createdAt == request.time;
      }
    }

    // Users
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin()) && isValidId(userId);
      allow create: if isSignedIn() && request.auth.uid == userId && isValidId(userId) && (
        incoming().role == 'customer' || (incoming().role == 'admin' && request.auth.token.email in ['vkalvaro1005@gmail.com', 'vishwa10230506@gmail.com'])
      );
      allow update: if isSignedIn() && request.auth.uid == userId && isValidId(userId) && (
        (!incoming().diff(existing()).affectedKeys().hasAny(['role']) && incoming().role == existing().role) || 
        (incoming().role == 'admin' && request.auth.token.email in ['vkalvaro1005@gmail.com', 'vishwa10230506@gmail.com'])
      );
    }
  }
}
